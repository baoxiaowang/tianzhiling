# 共享基础设施 / Docker Compose
DOCKER_VOLUME_DIRECTORY=.

REDIS_HOST=127.0.0.1
REDIS_PORT=17380
# REDIS_PASSWORD=
REDIS_DB=0

MONGO_HOST=127.0.0.1
MONGO_PORT=17271
MONGO_DB=tzl
MONGO_AUTH_SOURCE=admin
MONGO_USERNAME=admin
MONGO_PASSWORD=qwerasdf

ETCD_PORT=17239

MINIO_API_PORT=17900
MINIO_CONSOLE_PORT=17902
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

MILVUS_ADDRESS=127.0.0.1:17953
MILVUS_PORT=17953
MILVUS_HEALTH_PORT=19091
# MILVUS_TOKEN=
# MILVUS_USERNAME=
# MILVUS_PASSWORD=
MILVUS_DATABASE=default

# Node 服务基础 / 启动
NODE_APP_KEYS=replace-with-app-keys
NODE_PORT=7001

# Node JWT 鉴权
NODE_JWT_SECRET=replace-with-jwt-secret
NODE_JWT_EXPIRES_IN_SECONDS=604800

# Node 短信 / 容联云
NODE_CLOOPEN_SMS_ENABLED=false
# NODE_CLOOPEN_APP_ID=
# NODE_CLOOPEN_ACCOUNT_SID=
# NODE_CLOOPEN_AUTH_TOKEN=
NODE_CLOOPEN_SMS_TEMPLATE_ID=1
NODE_SMS_CODE_EXPIRES_IN_SECONDS=300
NODE_SMS_RESEND_INTERVAL_SECONDS=60

# Node AI / MiniMax
NODE_ENABLED=false
# NODE_API_KEY=
NODE_BASE_URL=https://api.minimax.io/v1
NODE_MODEL=MiniMax-M2.5
# 视觉能力请显式填写专用配置；即使和主模型相同，也不要省略
# NODE_VISION_API_KEY=
# NODE_VISION_BASE_URL=
# NODE_VISION_MODEL=
# 语音转文字请显式填写专用配置；即使和主模型相同，也不要省略
# NODE_SPEECH_TO_TEXT_API_KEY=
# NODE_SPEECH_TO_TEXT_BASE_URL=
# NODE_SPEECH_TO_TEXT_MODEL=
# 语音合成请显式填写专用配置；即使和主模型相同，也不要省略
# NODE_TEXT_TO_SPEECH_API_KEY=
# NODE_TEXT_TO_SPEECH_BASE_URL=
NODE_TEXT_TO_SPEECH_MODEL=qwen3-tts-vc-2026-01-22
# qwen3-tts-vc-2026-01-22 需要填写已复刻完成的音色名称
# NODE_TEXT_TO_SPEECH_VOICE=
NODE_TEXT_TO_SPEECH_LANGUAGE_TYPE=Chinese
NODE_TEMPERATURE=1
NODE_TOP_P=0.95
NODE_PRESENCE_PENALTY=0.6
NODE_FREQUENCY_PENALTY=0.3
NODE_MAX_RETRIES=2
NODE_TIMEOUT_MS=120000
NODE_REASONING_SPLIT=true

# Node 向量 Embedding
# Embedding 请显式填写专用配置；不再回退到其它变量名
# NODE_EMBEDDING_API_KEY=
# NODE_EMBEDDING_BASE_URL=
# NODE_EMBEDDING_MODEL=
# NODE_EMBEDDING_DIMENSIONS=

# Node Milvus
NODE_MILVUS_ENABLED=false
NODE_MILVUS_COLLECTION_NAME=conversation_message_memory
NODE_MILVUS_MAX_TEXT_LENGTH=4096
NODE_MILVUS_TOP_K=6
NODE_MILVUS_SEARCH_EF=64
# NODE_MILVUS_MIN_SCORE=
NODE_MILVUS_TIMEOUT_MS=10000



NODE_BULLMQ_PREFIX={tzl-bullmq}
NODE_BULLMQ_REMOVE_ON_COMPLETE=100
NODE_BULLMQ_REMOVE_ON_FAIL=500

# Node 阿里云 OSS
NODE_OSS_ENABLED=false
# NODE_OSS_REGION=
# NODE_OSS_BUCKET=
# NODE_OSS_ENDPOINT=
# NODE_OSS_PUBLIC_BASE_URL=
# NODE_OSS_ACCESS_KEY_ID=
# NODE_OSS_ACCESS_KEY_SECRET=
# NODE_OSS_STS_TOKEN=
NODE_OSS_SECURE=true
NODE_OSS_TIMEOUT_MS=60000
NODE_OSS_UPLOAD_PREFIX=static
NODE_OSS_SIGNED_URL_EXPIRE_SECONDS=900

# Node 腾讯云 COS
NODE_TENCENT_COS_ENABLED=false
# NODE_TENCENT_COS_REGION=
# NODE_TENCENT_COS_BUCKET=
# NODE_TENCENT_COS_SECRET_ID=
# NODE_TENCENT_COS_SECRET_KEY=
# NODE_TENCENT_COS_SECURITY_TOKEN=
NODE_TENCENT_COS_PROTOCOL=https:
# NODE_TENCENT_COS_DOMAIN=
# NODE_TENCENT_COS_PUBLIC_BASE_URL=
NODE_TENCENT_COS_UPLOAD_PREFIX=static
NODE_TENCENT_COS_SIGNED_URL_EXPIRE_SECONDS=900

# Node 数据库运行行为
NODE_DB_SYNCHRONIZE=true
NODE_DB_LOGGING=false
