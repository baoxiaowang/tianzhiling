MINIMAX_ENABLED=true
MINIMAX_API_KEY=your_minimax_api_key
MINIMAX_BASE_URL=https://api.minimaxi.com/v1
MINIMAX_MODEL=MiniMax-M2.5-highspeed
MINIMAX_VISION_API_KEY=your_vision_api_key
MINIMAX_VISION_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
MINIMAX_VISION_MODEL=qwen-vl-plus-latest

# 嵌入模型配
EMBEDDING_API_KEY=your_embedding_api_key
EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_MODEL=text-embedding-v4


SPEECH_TO_TEXT_API_KEY=your_speech_to_text_api_key
SPEECH_TO_TEXT_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
SPEECH_TO_TEXT_MODEL=qwen3-asr-flash

MINIMAX_TEMPERATURE=1
MINIMAX_MAX_RETRIES=2
MINIMAX_TIMEOUT_MS=120000
MINIMAX_REASONING_SPLIT=true

MILVUS_ENABLED=true
MILVUS_ADDRESS=127.0.0.1:17953
MILVUS_DATABASE=default

TENCENT_COS_ENABLED=true
TENCENT_COS_REGION=ap-guangzhou
TENCENT_COS_BUCKET=your-cos-bucket
TENCENT_COS_SECRET_ID=your_tencent_cos_secret_id
TENCENT_COS_SECRET_KEY=your_tencent_cos_secret_key
TENCENT_COS_SECURITY_TOKEN=
TENCENT_COS_PROTOCOL=https:
TENCENT_COS_DOMAIN=your-cos-domain.example.com
TENCENT_COS_PUBLIC_BASE_URL=https://your-cos-domain.example.com
TENCENT_COS_UPLOAD_PREFIX=static
TENCENT_COS_SIGNED_URL_EXPIRE_SECONDS=900
